;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DM IA"
run/main_scene="uid://b6r1u2idhgx5n"
config/features=PackedStringArray("4.5", "C#", "Mobile")
config/icon="res://icon.svg"

[autoload]

